{
  "manifest_version": 3,
  "name": "Power Automate Force v3=false",
  "version": "1.5.0",
  "description": "Forces v3=false on Power Automate flow/run URLs and normalizes v3survey=false when present.",
  "homepage_url": "https://helvety.com",
  "permissions": ["declarativeNetRequest", "webNavigation"],
  "host_permissions": ["https://*.powerautomate.com/*", "https://flow.microsoft.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "editor-v3-false-rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "assets/v3False_16.png",
    "32": "assets/v3False_32.png",
    "48": "assets/v3False_48.png",
    "128": "assets/v3False_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.powerautomate.com/*", "https://flow.microsoft.com/*"],
      "js": ["url-policy.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
