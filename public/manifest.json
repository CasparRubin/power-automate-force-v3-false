{
  "manifest_version": 3,
  "name": "Power Automate Editor Version Enforcer",
  "version": "2.1.0",
  "description": "Classic or new designer for Power Automate flow & run links. Survey Hide/Show for v3survey. Pause without uninstall.",
  "homepage_url": "https://helvety.com",
  "permissions": ["declarativeNetRequest", "webNavigation", "storage"],
  "host_permissions": ["https://*.powerautomate.com/*", "https://flow.microsoft.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Power Automate Editor Version Enforcer"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "dnr-classic-editor",
        "enabled": true,
        "path": "dnr-classic-editor.json"
      },
      {
        "id": "dnr-new-designer",
        "enabled": false,
        "path": "dnr-new-designer.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.powerautomate.com/*", "https://flow.microsoft.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
