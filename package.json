{
  "name": "power-automate-version-enforcer",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CasparRubin/power-automate-editor-version-enforcer.git"
  },
  "scripts": {
    "prebuild": "node scripts/prebuild-copy-public.mjs",
    "build:sw": "esbuild src/background.ts --bundle --outfile=dist/background.js --format=esm --platform=browser --target=es2022",
    "build:content": "esbuild src/content.ts --bundle --outfile=dist/content.js --format=iife --platform=browser --target=es2022",
    "build:popup": "vite build --config vite.popup.config.ts",
    "build": "npm run prebuild && npm run build:sw && npm run build:content && npm run build:popup",
    "watch": "vite build --config vite.popup.config.ts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:naming": "node scripts/verify-project-naming.mjs",
    "predeploy": "npm run verify:naming && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  }
}
